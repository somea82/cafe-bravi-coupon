# Public application URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase browser credentials
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase server-only credential. Never expose this with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=

# Kakao JavaScript SDK
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=

# Server-only secrets
QR_TOKEN_SECRET=
COOKIE_SECRET=
COUPON_TOKEN_SECRET=

# Operational value used to create the physical QR. Not required by the app.
BRAVI_QR_TOKEN=

# Local operational credentials. Do not add these to Vercel or commit them.
BRAVI_STAFF_EMAIL=
BRAVI_STAFF_PASSWORD=
